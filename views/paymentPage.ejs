<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pembayaran - JSkuy</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --pink: #ff90e8;
            --yellow: #ffc900;
            --blue: #23a094;
            --ink: #111;
            --cream: #f4f4f0;
            --green: #90ff9a;
        }

        body {
            background-color: var(--cream);
            font-family: 'Space Grotesk', sans-serif;
        }

        .brutal-btn {
            display: inline-block;
            border: 4px solid var(--ink);
            box-shadow: 6px 6px 0 var(--ink);
            font-weight: 900;
            text-transform: uppercase;
            transition: all 0.2s ease;
            text-decoration: none;
            color: var(--ink);
        }

        .brutal-btn:hover {
            transform: translate(2px, 2px);
            box-shadow: 4px 4px 0 var(--ink);
            color: var(--ink);
        }

        .brutal-box {
            background: #fff;
            border: 6px solid var(--ink);
            box-shadow: 12px 12px 0 var(--ink);
        }

        .qr-box {
            width: 240px;
            height: 240px;
            border: 4px solid var(--ink);
            box-shadow: 6px 6px 0 var(--ink);
            background: repeating-linear-gradient(
                45deg,
                #000,
                #000 10px,
                #fff 10px,
                #fff 20px
            );
            margin: 0 auto;
        }
    </style>
</head>
<body>
    <main class="container py-5">
        <div style="max-width: 800px; margin: 0 auto;">
            <div class="brutal-box p-5 text-center" style="background: var(--yellow);">
                <h1 style="font-family: 'Archivo Black', sans-serif; font-size: 2.5rem; text-transform: uppercase;">
                    Scan QR Pembayaran
                </h1>

                <p class="mt-3 mb-4 fw-bold">
                    Selesaikan pembayaran untuk course <%= course.title %>
                </p>

                <div class="qr-box mb-4"></div>

                <div class="mb-4">
                    <p class="mb-2"><strong>Invoice:</strong> <%= transaction.invoiceNumber %></p>
                    <p class="mb-0"><strong>Total:</strong> Rp <%= Number(transaction.totalAmount).toLocaleString('id-ID') %></p>
                </div>

                <form action="/home/courses/<%= course.id %>/transaction/pay" method="POST">
                    <button type="submit" class="brutal-btn text-dark"
                        style="background: var(--green); font-size: 1.2rem; padding: 1rem 2rem; border-radius: 0;">
                        SELESAI BAYAR
                    </button>
                </form>
            </div>
        </div>
    </main>
</body>
</html>