<!DOCTYPE html>
<html lang="id">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Masuk - EduMarket</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
   <link rel="preconnect" href="https://fonts.googleapis.com">
   <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet">
   <style>
      :root {
         --ink: #111111;
         --cream: #FFF6E0;
         --yellow: #FFD400;
         --pink: #FF4FA3;
         --blue: #3D7BFF;
         --green: #7CFF6B;
      }

      * {
         box-sizing: border-box;
      }

      body {
         margin: 0;
         min-height: 100vh;
         font-family: 'Space Grotesk', sans-serif;
         color: var(--ink);
         background-color: var(--cream);
         background-image: radial-gradient(var(--ink) 1.5px, transparent 1.5px);
         background-size: 22px 22px;
         display: flex;
         align-items: center;
         justify-content: center;
         padding: 2.5rem 1.25rem;
      }

      .stage {
         position: relative;
         width: 100%;
         max-width: 440px;
      }

      /* sticker logo nempel di atas card */
      .brand-stamp {
         position: absolute;
         top: -26px;
         left: 18px;
         background: var(--ink);
         color: #fff;
         font-family: 'Archivo Black', sans-serif;
         font-size: 1rem;
         padding: 0.55rem 1rem;
         border: 3px solid var(--ink);
         transform: rotate(-4deg);
         z-index: 3;
         letter-spacing: 0.5px;
      }

      /* sticker badge di pojok kanan atas */
      .badge-sticker {
         position: absolute;
         top: -18px;
         right: -12px;
         background: var(--green);
         border: 3px solid var(--ink);
         color: var(--ink);
         font-weight: 700;
         font-size: 0.72rem;
         text-transform: uppercase;
         padding: 0.4rem 0.7rem;
         transform: rotate(8deg);
         z-index: 3;
         box-shadow: 4px 4px 0 var(--ink);
      }

      /* blok warna di belakang card, bikin efek layer */
      .backer {
         position: absolute;
         inset: 0;
         background: var(--blue);
         border: 4px solid var(--ink);
         transform: translate(14px, 14px);
         z-index: 0;
      }

      .card {
         position: relative;
         z-index: 2;
         background: #fff;
         border: 4px solid var(--ink);
         box-shadow: 10px 10px 0 var(--ink);
         padding: 2.6rem 2.2rem 2.2rem;
      }

      .card h1 {
         font-family: 'Archivo Black', sans-serif;
         font-size: 2rem;
         line-height: 1.1;
         text-transform: uppercase;
         margin: 0 0 0.6rem;
      }

      .card .subtitle {
         font-weight: 600;
         font-size: 0.92rem;
         margin-bottom: 2rem;
         border-left: 4px solid var(--pink);
         padding-left: 0.6rem;
      }

      .form-label {
         font-weight: 700;
         text-transform: uppercase;
         font-size: 0.78rem;
         letter-spacing: 0.5px;
         margin-bottom: 0.4rem;
      }

      .form-control {
         border: 3px solid var(--ink);
         border-radius: 0;
         padding: 0.65rem 0.85rem;
         font-weight: 600;
         font-family: 'Space Grotesk', sans-serif;
         background: #fff;
         box-shadow: none;
      }

      .form-control:focus {
         border-color: var(--ink);
         background: var(--yellow);
         box-shadow: 4px 4px 0 var(--ink);
         outline: none;
      }

      .form-control::placeholder {
         color: #999;
         font-weight: 500;
      }

      .mb-3 {
         margin-bottom: 1.3rem !important;
      }

      .form-check-input {
         border: 2.5px solid var(--ink);
         border-radius: 0;
         width: 1.15em;
         height: 1.15em;
      }

      .form-check-input:checked {
         background-color: var(--ink);
         border-color: var(--ink);
      }

      .form-check-label {
         font-weight: 600;
         font-size: 0.9rem;
      }

      .forgot-link {
         font-weight: 700;
         font-size: 0.85rem;
         color: var(--ink);
         text-decoration: underline;
         text-decoration-thickness: 2px;
      }

      .forgot-link:hover {
         background: var(--yellow);
      }

      .btn-login {
         width: 100%;
         background: var(--pink);
         border: 3px solid var(--ink);
         border-radius: 0;
         color: var(--ink);
         font-family: 'Archivo Black', sans-serif;
         font-size: 1rem;
         text-transform: uppercase;
         padding: 0.8rem;
         box-shadow: 6px 6px 0 var(--ink);
         transition: transform .1s ease, box-shadow .1s ease;
      }

      .btn-login:hover,
      .btn-login:focus {
         color: var(--ink);
         background: var(--yellow);
      }

      .btn-login:active {
         transform: translate(4px, 4px);
         box-shadow: 2px 2px 0 var(--ink);
      }

      .btn-login:focus-visible,
      .form-control:focus-visible,
      .forgot-link:focus-visible {
         outline: 3px solid var(--blue);
         outline-offset: 2px;
      }

      .register-text {
         text-align: center;
         margin-top: 1.8rem;
         font-weight: 600;
         font-size: 0.9rem;
      }

      .register-text a {
         color: var(--ink);
         font-weight: 800;
         text-decoration: underline;
         text-decoration-color: var(--blue);
         text-decoration-thickness: 3px;
      }

      @media (prefers-reduced-motion: reduce) {
         .btn-login {
            transition: none;
         }
      }

      @media (max-width:480px) {
         .card {
            padding: 2.2rem 1.4rem 1.8rem;
         }

         .card h1 {
            font-size: 1.6rem;
         }

         .brand-stamp {
            font-size: 0.85rem;
            left: 12px;
         }
      }
   </style>
</head>

<body>

   <div class="stage">
      <div class="brand-stamp">JSKuy</div>
      <div class="badge-sticker">100% Bermanfaat</div>
      <div class="backer" aria-hidden="true"></div>

      <div class="card">
         <h1>Masuk Akun</h1>
         <p class="subtitle">Lanjutin progres belajarmu sekarang.</p>

         <form action="/login" method="POST" novalidate>
            <div class="mb-3">
               <label for="email" class="form-label">Email</label>
               <input type="email" class="form-control" id="email" name="email" placeholder="nama@email.com" required>
            </div>

            <div class="mb-3">
               <label for="password" class="form-label">Kata Sandi</label>
               <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required
                  minlength="8">
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
               <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="remember" name="remember">
                  <label class="form-check-label" for="remember">Ingat saya</label>
               </div>
               <a href="#" class="forgot-link">Lupa sandi?</a>
            </div>

            <button type="submit" class="btn btn-login">Masuk Sekarang</button>
         </form>

         <p class="register-text">Belum punya akun? <a href="/register">Daftar di sini</a></p>
      </div>
   </div>

</body>

</html>