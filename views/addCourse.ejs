<!DOCTYPE html>
<html lang="id">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Tambah Course Baru - JSkuy</title>
   <link rel="icon" type="image/png" href="/assets/pavicon.png">
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
   <link rel="preconnect" href="https://fonts.googleapis.com">
   <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@500;600;700;800&display=swap"
      rel="stylesheet">

   <style>
      /* CSS Variabel bawaan Brutalism kita */
      :root {
         --pink: #ff90e8;
         --yellow: #ffc900;
         --blue: #23a094;
         --ink: #111;
         --cream: #f4f4f0;
         --green: #90ff9a;
      }

      /* ================= NAVBAR ================= */
      .brutal-nav {
         background-color: #fff;
         border-bottom: 4px solid var(--ink);
         padding: 1rem 0;
      }

      .navbar-brand {
         font-family: 'Archivo Black', sans-serif;
         font-size: 1.8rem;
         color: var(--ink) !important;
         background: var(--green);
         padding: 0.2rem 1rem;
         border: 3px solid var(--ink);
         transform: rotate(-2deg);
         box-shadow: 4px 4px 0 var(--ink);
      }

      .nav-link {
         font-weight: 700;
         color: var(--ink) !important;
         font-size: 1.1rem;
         border: 2px solid transparent;
         padding: 0.5rem 1rem !important;
      }

      .nav-link:hover {
         background-color: var(--yellow);
         border: 2px solid var(--ink);
      }

      /* Base Style Button (Bawaan dari home) */
      .brutal-btn {
         display: inline-block;
         border: 4px solid var(--ink);
         box-shadow: 6px 6px 0 var(--ink);
         font-weight: 900;
         text-transform: uppercase;
         transition: all 0.2s ease;
      }

      .brutal-btn:hover {
         transform: translate(2px, 2px);
         box-shadow: 4px 4px 0 var(--ink);
      }

      /* Style Khusus untuk Input Form */
      .brutal-input {
         border: 4px solid var(--ink);
         padding: 1rem;
         font-size: 1rem;
         font-weight: 500;
         width: 100%;
         transition: all 0.2s ease;
         background: #fff;
         border-radius: 0;
      }

      .brutal-input:focus {
         outline: none;
         background: var(--cream);
         box-shadow: 6px 6px 0 var(--ink);
         transform: translate(-2px, -2px);
      }

      /* ================= FOOTER ================= */
      .brutal-footer {
         margin-top: auto;
         background: var(--blue);
         border-top: 4px solid var(--ink);
         padding: 3rem 0;
      }

      .footer-title {
         font-size: 2.5rem;
         color: #fff;
         text-shadow: 3px 3px 0 var(--ink);
         margin-bottom: 1rem;
      }

      .footer-links a {
         color: var(--ink);
         font-weight: 800;
         text-decoration: none;
         border-bottom: 3px solid var(--ink);
         margin-right: 1.5rem;
         font-size: 1.1rem;
      }

      .footer-links a:hover {
         background: var(--yellow);
      }
   </style>
</head>

<body>

   <!-- NAVBAR -->
   <nav class="navbar navbar-expand-lg brutal-nav sticky-top">
      <div class="container">
         <a class="navbar-brand" href="/home">JSkuy</a>
         <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            style="border: 3px solid var(--ink); border-radius: 0;">
            <span class="navbar-toggler-icon"></span>
         </button>
         <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
               <li class="nav-item dropdown">

                  <!-- Button Profil -->
                  <a class="nav-link dropdown-toggle brutal-btn text-decoration-none" href="#" id="profileDropdown"
                     role="button" data-bs-toggle="dropdown" aria-expanded="false"
                     style="background: var(--pink); font-size: 1rem; padding: 0.5rem 1rem; border-radius: 0;">
                     HALO, <%= user.username.toUpperCase() %>
                  </a>

                  <!-- Menu Dropdown -->
                  <ul class="dropdown-menu dropdown-menu-end mt-2" aria-labelledby="profileDropdown"
                     style="border: 4px solid var(--ink); border-radius: 0; box-shadow: 6px 6px 0 var(--ink); background: #fff; padding: 0;">
                     <li><a class="dropdown-item fw-bold py-2" href="/profile" style="font-size: 1rem;">Lihat Profil</a>
                     </li>
                     <li>
                        <hr class="dropdown-divider m-0" style="border-top: 3px solid var(--ink);">
                     </li>
                     <li class="p-2">
                        <form action="/logout" method="GET" class="m-0">
                           <button type="submit" class="brutal-btn w-100"
                              style="background: var(--yellow); font-size: 0.9rem; padding: 0.4rem;">KELUAR</button>
                        </form>
                     </li>
                  </ul>
               </li>
            </ul>
         </div>
      </div>
   </nav>
   <!-- END NAVBAR -->

   <main class="container py-5 mt-3 mb-5">
      <div style="max-width: 800px; margin: 0 auto;">

         <a href="/home" class="brutal-btn text-decoration-none text-dark mb-4 d-inline-block"
            style="background: #fff; padding: 0.5rem 1rem;">
            KEMBALI
         </a>

         <div
            style="background: var(--yellow); border: 6px solid var(--ink); box-shadow: 12px 12px 0 var(--ink); padding: 3rem;">

            <h1
               style="font-family: 'Archivo Black', sans-serif; font-size: 2.5rem; text-transform: uppercase; margin-bottom: 2rem; border-bottom: 6px solid var(--ink); padding-bottom: 1rem;">
               + Tambah Course
            </h1>

            <% if (error) { %>
               <div
                  style="background: #ffdddd; border: 3px solid var(--ink); padding: 1rem; margin-bottom: 1.5rem; font-weight: bold; color: #b00020;">
                  <ul style="margin: 0; padding-left: 1.2rem;">
                     <% error.split('||').forEach(function(msg) { %>
                        <li>
                           <%= msg %>
                        </li>
                        <% }) %>
                  </ul>
               </div>
               <% } %>

                  <form action="/home/add" method="POST">

                     <div class="mb-4">
                        <label for="title" class="fw-bold mb-2 fs-5">Judul Course <span
                              class="text-danger">*</span></label>
                        <input type="text" id="title" name="title" class="brutal-input"
                           placeholder="Contoh: Masterclass Web Backend">
                     </div>

                     <div class="mb-4">
                        <label for="description" class="fw-bold mb-2 fs-5">Deskripsi Lengkap <span
                              class="text-danger">*</span></label>
                        <textarea id="description" name="description" class="brutal-input" rows="5"
                           placeholder="Jelaskan secara singkat apa saja yang akan dipelajari di course ini..."></textarea>
                     </div>

                     <div class="row mb-4 g-4">
                        <div class="col-md-6">
                           <label for="price" class="fw-bold mb-2 fs-5">Harga (Rp) <span
                                 class="text-danger">*</span></label>
                           <input type="number" id="price" name="price" class="brutal-input"
                              placeholder="Contoh: 150000" min="0">
                        </div>

                        <div class="col-md-6">
                           <label for="imageUrl" class="fw-bold mb-2 fs-5">URL Gambar <span
                                 class="text-danger">*</span></label>
                           <input type="text" id="imageUrl" name="imageUrl" class="brutal-input"
                              placeholder="https://contoh-gambar.com/img.jpg">
                        </div>
                     </div>

                     <button type="submit" class="brutal-btn text-dark w-100 mt-4"
                        style="background: var(--green); font-size: 1.5rem; padding: 1rem; border-radius: 0;">
                        SIMPAN COURSE
                     </button>

                  </form>
         </div>

      </div>
   </main>

   <footer class="brutal-footer">
      <div class="container text-center text-md-start">
         <div class="row align-items-center">
            <div class="col-md-6 mb-4 mb-md-0">
               <h2 class="footer-title">JSkuy.</h2>
               <p class="fw-bold fs-5 mb-0" style="color: var(--ink);">Gudang ilmu tanpa batas.</p>
            </div>
            <div class="col-md-6 text-md-end footer-links">
               <a href="#">Tentang Kami</a>
               <a href="#">Bantuan</a>
               <a href="#">Syarat & Ketentuan</a>
            </div>
         </div>
      </div>
   </footer>

   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>