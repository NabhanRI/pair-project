<!DOCTYPE html>
<html lang="id">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Home - JSKuy</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
   <link rel="preconnect" href="https://fonts.googleapis.com">
   <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@500;600;700;800&display=swap"
      rel="stylesheet">

   <style>
      :root {
         --ink: #111111;
         --cream: #FFF6E0;
         --yellow: #FFD400;
         --pink: #FF4FA3;
         --blue: #3D7BFF;
         --green: #7CFF6B;
         --purple: #B266FF;
      }

      * {
         box-sizing: border-box;
      }

      body {
         margin: 0;
         font-family: 'Space Grotesk', sans-serif;
         color: var(--ink);
         background-color: var(--cream);
         background-image: radial-gradient(var(--ink) 1.5px, transparent 1.5px);
         background-size: 22px 22px;
         display: flex;
         flex-direction: column;
         min-height: 100vh;
      }

      h1,
      h2,
      h3,
      h4 {
         font-family: 'Archivo Black', sans-serif;
         text-transform: uppercase;
         margin: 0;
      }

      /* ================= NAVBAR ================= */
      .brutal-nav {
         background-color: #fff;
         border-bottom: 4px solid var(--ink);
         padding: 1rem 0;
      }

      .navbar-brand {
         font-family: 'Archivo Black', sans-serif;
         font-size: 1.8rem;
         color: var(--ink) !important;
         background: var(--green);
         padding: 0.2rem 1rem;
         border: 3px solid var(--ink);
         transform: rotate(-2deg);
         box-shadow: 4px 4px 0 var(--ink);
      }

      .nav-link {
         font-weight: 700;
         color: var(--ink) !important;
         font-size: 1.1rem;
         border: 2px solid transparent;
         padding: 0.5rem 1rem !important;
      }

      .nav-link:hover {
         background-color: var(--yellow);
         border: 2px solid var(--ink);
      }

      /* ================= SEARCH BAR ================= */
      .search-container {
         margin: 3rem 0;
         padding: 2rem;
         background: var(--purple);
         border: 4px solid var(--ink);
         box-shadow: 8px 8px 0 var(--ink);
      }

      .search-form {
         display: flex;
         gap: 10px;
      }

      .search-input {
         flex-grow: 1;
         border: 3px solid var(--ink);
         border-radius: 0;
         padding: 1rem;
         font-weight: 600;
         font-family: 'Space Grotesk', sans-serif;
         font-size: 1.1rem;
      }

      .search-input:focus {
         outline: none;
         background: var(--yellow);
         box-shadow: inset 4px 4px 0 var(--ink);
      }

      .brutal-btn {
         background: var(--pink);
         border: 3px solid var(--ink);
         color: var(--ink);
         font-family: 'Archivo Black', sans-serif;
         padding: 0 1.5rem;
         font-size: 1.1rem;
         box-shadow: 4px 4px 0 var(--ink);
         transition: transform 0.1s ease, box-shadow 0.1s ease;
         cursor: pointer;
      }

      .brutal-btn:active {
         transform: translate(4px, 4px);
         box-shadow: 0px 0px 0 var(--ink);
      }

      /* ================= CARDS ================= */
      .brutal-card {
         background: #fff;
         border: 4px solid var(--ink);
         box-shadow: 8px 8px 0 var(--ink);
         height: 100%;
         display: flex;
         flex-direction: column;
         transition: transform 0.2s ease;
      }

      .brutal-card:hover {
         transform: translateY(-5px);
      }

      .card-img-wrapper {
         border-bottom: 4px solid var(--ink);
         background: var(--blue);
         height: 200px;
         overflow: hidden;
      }

      .card-img-wrapper img {
         width: 100%;
         height: 100%;
         object-fit: cover;
         filter: grayscale(20%) contrast(120%);
      }

      .card-body-brutal {
         padding: 1.5rem;
         flex-grow: 1;
         display: flex;
         flex-direction: column;
      }

      .card-title {
         font-size: 1.4rem;
         margin-bottom: 0.5rem;
      }

      .card-author {
         font-weight: 700;
         color: var(--pink);
         margin-bottom: 1rem;
         font-size: 0.9rem;
      }

      .card-price {
         background: var(--yellow);
         display: inline-block;
         padding: 0.3rem 0.8rem;
         border: 3px solid var(--ink);
         font-family: 'Archivo Black', sans-serif;
         font-size: 1.2rem;
         margin-top: auto;
         align-self: flex-start;
      }

      /* ================= FOOTER ================= */
      .brutal-footer {
         margin-top: auto;
         background: var(--blue);
         border-top: 4px solid var(--ink);
         padding: 3rem 0;
      }

      .footer-title {
         font-size: 2.5rem;
         color: #fff;
         text-shadow: 3px 3px 0 var(--ink);
         margin-bottom: 1rem;
      }

      .footer-links a {
         color: var(--ink);
         font-weight: 800;
         text-decoration: none;
         border-bottom: 3px solid var(--ink);
         margin-right: 1.5rem;
         font-size: 1.1rem;
      }

      .footer-links a:hover {
         background: var(--yellow);
      }
   </style>
</head>

<body>

   <!-- NAVBAR -->
   <nav class="navbar navbar-expand-lg brutal-nav sticky-top">
      <div class="container">
         <a class="navbar-brand" href="/home">JSkuy</a>
         <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            style="border: 3px solid var(--ink); border-radius: 0;">
            <span class="navbar-toggler-icon"></span>
         </button>
         <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
               <li class="nav-item dropdown">

                  <!-- Button Profil -->
                  <a class="nav-link dropdown-toggle brutal-btn text-decoration-none" href="#" id="profileDropdown"
                     role="button" data-bs-toggle="dropdown" aria-expanded="false"
                     style="background: var(--pink); font-size: 1rem; padding: 0.5rem 1rem; border-radius: 0;">
                     HALO, <%= user.username.toUpperCase() %>
                  </a>

                  <!-- Menu Dropdown -->
                  <ul class="dropdown-menu dropdown-menu-end mt-2" aria-labelledby="profileDropdown"
                     style="border: 4px solid var(--ink); border-radius: 0; box-shadow: 6px 6px 0 var(--ink); background: #fff; padding: 0;">
                     <li><a class="dropdown-item fw-bold py-2" href="/profile" style="font-size: 1rem;">Lihat Profil</a>
                     </li>
                     <li>
                        <hr class="dropdown-divider m-0" style="border-top: 3px solid var(--ink);">
                     </li>
                     <li class="p-2">
                        <form action="/logout" method="GET" class="m-0">
                           <button type="submit" class="brutal-btn w-100"
                              style="background: var(--yellow); font-size: 0.9rem; padding: 0.4rem;">KELUAR</button>
                        </form>
                     </li>
                  </ul>
               </li>
            </ul>
         </div>
      </div>
   </nav>
   <!-- END NAVBAR -->

   <main class="container py-4 flex-grow-1">

      <section class="search-container">
         <h2 class="mb-3 text-white" style="text-shadow: 2px 2px 0 var(--ink);">Cari Kursus Incaranmu!</h2>
         <form class="search-form" action="/home" method="GET">
            <input type="text" name="search" class="search-input" placeholder="Ketik judul kursus...">
            <button type="submit" class="brutal-btn">CARI</button>
         </form>
      </section>

      <div class="d-flex justify-content-between align-items-end mb-4">
         <h2
            style="font-size: 2.2rem; background: var(--green); display: inline-block; padding: 0.2rem 0.8rem; border: 3px solid var(--ink); box-shadow: 4px 4px 0 var(--ink);">
            Rekomendasi Kursus
         </h2>

         <!-- LOGIKA RENDER KHUSUS ADMIN -->
         <% if (user && user.role==='admin' ) { %>
            <a href="/home/add" class="brutal-btn text-decoration-none text-dark"
               style="background: var(--yellow); padding: 0.6rem 1.2rem; font-size: 1.1rem;">
               + TAMBAH KURSUS
            </a>
            <% } %>
      </div>

      <!-- CARD COURSE -->
      <div class="row g-4 mb-5">
         <!-- Cek apakah data courses kosong (misal karena keyword tidak ditemukan) -->
         <% if (courses.length===0) { %>
            <div class="col-12 text-center py-5">
               <h3
                  style="background: var(--pink); display: inline-block; padding: 0.5rem 1rem; border: 3px solid var(--ink); box-shadow: 4px 4px 0 var(--ink);">
                  Yah, course yang kamu cari nggak ada nih :(
               </h3>
            </div>
            <% } else { %>
               <!-- Looping data courses dari database -->
               <% courses.forEach(course=> { %>
                  <div class="col-12 col-md-6 col-lg-4">
                     <div class="brutal-card">
                        <div class="card-img-wrapper">
                           <!-- Mengambil imageUrl dari database, jika kosong pakai gambar default -->
                           <img
                              src="<%= course.imageUrl || 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=500&auto=format&fit=crop' %>"
                              alt="<%= course.title %>">
                        </div>
                        <div class="card-body-brutal">
                           <h3 class="card-title">
                              <%= course.title %>
                           </h3>

                           <!-- Menampilkan Rating -->
                           <div class="card-author" style="color: var(--blue);">
                              ⭐ Rating: <%= course.rating %> / 5.0 
                           </div>

                           <p class="fw-semibold mb-4">
                              <%= course.description %>
                           </p>

                           <!-- List button -->
                           <div class="mt-auto pt-3">
                              <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">

                                 <div class="card-price m-0">
                                    <%= course.formatRupiah %>
                                 </div>

                                 <div class="d-flex gap-2">
                                    <a href="#" class="brutal-btn text-decoration-none text-dark"
                                       style="background: var(--yellow); padding: 0.4rem 0.8rem; font-size: 0.9rem;">
                                       BELI
                                    </a>
                                    <a href="/home/courses/<%= course.id %>"
                                       class="brutal-btn text-decoration-none text-dark"
                                       style="background: var(--pink); padding: 0.4rem 0.8rem; font-size: 0.9rem;">
                                       DETAIL
                                    </a>
                                 </div>
                              </div>
                           </div>
                        </div>
                     </div>
                  </div>
               <% }) %>
         <% } %>
      </div>
      <!-- END CARD COURSE -->

   </main>

   <footer class="brutal-footer">
      <div class="container text-center text-md-start">
         <div class="row align-items-center">
            <div class="col-md-6 mb-4 mb-md-0">
               <h2 class="footer-title">JSkuy.</h2>
               <p class="fw-bold fs-5 mb-0" style="color: var(--ink);">Gudang ilmu tanpa batas.</p>
            </div>
            <div class="col-md-6 text-md-end footer-links">
               <a href="#">Tentang Kami</a>
               <a href="#">Bantuan</a>
               <a href="#">Syarat & Ketentuan</a>
            </div>
         </div>
      </div>
   </footer>

   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>