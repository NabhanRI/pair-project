<!DOCTYPE html>
<html lang="id">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>
      <%= course.title %> - JSkuy
   </title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

   <style>
      :root {
         --ink: #111111;
         --cream: #FFF6E0;
         --yellow: #FFD400;
         --pink: #FF4FA3;
         --blue: #3D7BFF;
         --green: #7CFF6B;
         --purple: #B266FF;
      }

      .brutal-btn {
         display: inline-block;
         border: 4px solid var(--ink);
         box-shadow: 6px 6px 0 var(--ink);
         font-weight: 900;
         text-transform: uppercase;
         transition: all 0.2s ease;
         text-decoration: none;
         color: var(--ink);
      }

      .brutal-btn:hover {
         transform: translate(2px, 2px);
         box-shadow: 4px 4px 0 var(--ink);
         color: var(--ink);
      }

      .brutal-box {
         border: 6px solid var(--ink);
         box-shadow: 12px 12px 0 var(--ink);
         background-color: #fff;
      }
   </style>
</head>

<body style="background-color: var(--cream); font-family: 'Space Grotesk', sans-serif;">

   <main class="container py-5">

      <a href="/home" class="brutal-btn mb-4" style="background: #fff; padding: 0.5rem 1rem;">
         KEMBALI KE HOME
      </a>

      <div class="row g-5 align-items-center">

         <div class="col-md-6">
            <div class="brutal-box p-0 overflow-hidden" style="background-color: var(--blue);">
               <% if (course.imageUrl) { %>
                  <img src="<%= course.imageUrl %>" alt="<%= course.title %>"
                     style="width: 100%; height: 400px; object-fit: cover; border-bottom: 6px solid var(--ink);">
                  <% } else { %>
                     <div
                        style="width: 100%; height: 400px; display: flex; align-items: center; justify-content: center;">
                        <h2 style="font-family: 'Archivo Black';">NO IMAGE</h2>
                     </div>
                     <% } %>
            </div>
         </div>

         <div class="col-md-6">
            <div class="d-inline-block mb-3"
               style="background: var(--ink); color: var(--yellow); padding: 0.3rem 1rem; font-weight: bold; border-radius: 50px;">
               ⭐ <%= course.rating %> / 5.0
            </div>

            <h1
               style="font-family: 'Archivo Black', sans-serif; font-size: 3rem; line-height: 1.1; text-transform: uppercase; margin-bottom: 1.5rem;">
               <%= course.title %>
            </h1>

            <h2 style="font-weight: 800; font-size: 2.5rem; color: var(--blue); margin-bottom: 1.5rem;">
               <%= course.formatRupiah %>
            </h2>

            <div class="brutal-box p-4 mb-4" style="background: var(--yellow); box-shadow: 6px 6px 0 var(--ink);">
               <h5 class="fw-bold mb-2 border-bottom border-dark pb-2">Apa yang akan kamu pelajari?</h5>
               <p style="font-size: 1.1rem; white-space: pre-line; margin: 0;">
                  <%= course.description %>
               </p>
            </div>

            <div class="d-flex gap-3 mt-4">

               <% if (user && user.role ==='admin' ) { %>
                  <a href="/home/courses/<%= course.id %>/edit" class="brutal-btn w-50 text-center"
                     style="background: var(--blue); padding: 1rem; font-size: 1.2rem;">
                     EDIT
                  </a>

                  <a href="/home/courses/<%= course.id %>/delete" class="brutal-btn w-50 text-center"
                     style="background: var(--pink); padding: 1rem; font-size: 1.2rem;"
                     onclick="return confirm('Yakin ingin menghapus materi JSkuy ini?')">
                     HAPUS
                  </a>

                  <% } else { %>
                     <a href="#" class="brutal-btn w-100 text-center"
                        style="background: var(--green); padding: 1rem; font-size: 1.5rem;">
                        DAFTAR JSKUY SEKARANG
                     </a>
                     <% } %>

            </div>

         </div>
      </div>

   </main>

</body>

</html>